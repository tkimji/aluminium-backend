generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  tech
  user
}

enum UserStatus {
  active
  inactive
}

enum ApprovalType {
  tech_registration
  payment_slip
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum SubscriptionPlan {
  monthly
  yearly
}

enum SubscriptionStatus {
  pending
  active
  expired
}

enum PaymentStatus {
  pending
  approved
  rejected
}

enum ItemFormat {
  MTO
  PRESET
  MATERIAL
}

enum ProjectItemStatus {
  DRAFT
  IN_CART
  QUOTED
}

enum ProductStatus {
  active
  inactive
}

enum PriceSource {
  MANUAL
  FORMULA
}

enum ProjectStatus {
  draft
  quoted
  ordered
  paid
  done
}

enum QuoteStatus {
  draft
  sent
  approved
  void
}

enum OrderStatus {
  awaiting_payment
  verifying
  paid
  preparing
  shipped
  completed
  cancelled
}

enum NotificationTone {
  green
  orange
  yellow
}

enum NotificationStatus {
  unread
  read
}

enum WarehouseStatus {
  active
  inactive
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

model User {
  id           String           @id @default(uuid())
  role         Role
  email        String           @unique
  phone        String?
  passwordHash String           @map("password_hash")
  status       UserStatus       @default(active)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  profile      UserProfile?
  approvals    AdminApproval[]  @relation("approval_subject")
  approvalsBy  AdminApproval[]  @relation("approval_admin")
  subscriptions Subscription[]
  subscriptionPayments SubscriptionPayment[]
  projects     Project[]
  notifications Notification[]
  payments     Payment[]
  stockMovements StockMovement[]
}

model UserProfile {
  id          String  @id @default(uuid())
  userId      String  @unique @map("user_id")
  prefix      String?
  firstName   String  @map("first_name")
  lastName    String  @map("last_name")
  houseNo     String? @map("house_no")
  moo         String?
  road        String?
  province    String?
  district    String?
  subdistrict String?
  postalCode  String? @map("postal_code")

  user User @relation(fields: [userId], references: [id])
}

model AdminApproval {
  id          String         @id @default(uuid())
  userId      String         @map("user_id")
  type        ApprovalType
  status      ApprovalStatus @default(pending)
  note        String?
  approvedBy  String?        @map("approved_by")
  approvedAt  DateTime?      @map("approved_at")
  createdAt   DateTime       @default(now()) @map("created_at")

  subject User  @relation("approval_subject", fields: [userId], references: [id])
  admin   User? @relation("approval_admin", fields: [approvedBy], references: [id])
}

model Subscription {
  id        String            @id @default(uuid())
  userId    String            @map("user_id")
  plan      SubscriptionPlan
  status    SubscriptionStatus @default(pending)
  startAt   DateTime?         @map("start_at")
  endAt     DateTime?         @map("end_at")
  createdAt DateTime          @default(now()) @map("created_at")

  user     User                  @relation(fields: [userId], references: [id])
  payments SubscriptionPayment[]
}

model SubscriptionPayment {
  id             String        @id @default(uuid())
  subscriptionId String        @map("subscription_id")
  slipUrl        String        @map("slip_url")
  status         PaymentStatus @default(pending)
  approvedBy     String?       @map("approved_by")
  approvedAt     DateTime?     @map("approved_at")
  createdAt      DateTime      @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  admin        User?        @relation(fields: [approvedBy], references: [id])
}

model ProductType {
  id        String   @id @default(uuid())
  code      String?
  name      String
  status    ProductStatus @default(active)
  createdAt DateTime @default(now()) @map("created_at")

  products Product[]
  formulas Formula[]
}

model Unit {
  id        String   @id @default(uuid())
  code      String?
  name      String
  status    ProductStatus @default(active)
  createdAt DateTime @default(now()) @map("created_at")

  products Product[]
  formulas Formula[]
}

model AluminiumItem {
  id        String        @id @default(uuid())
  code      String?
  name      String
  imagePath String?       @map("image_path")
  status    ProductStatus @default(active)
  createdAt DateTime      @default(now()) @map("created_at")
}

model Brand {
  id        String   @id @default(uuid())
  code      String?
  name      String
  status    ProductStatus @default(active)
  createdAt DateTime @default(now()) @map("created_at")

  products Product[]
  projectItems ProjectItem[]
  orderItems OrderItem[]
}

model Color {
  id        String   @id @default(uuid())
  code      String?
  name      String
  status    ProductStatus @default(active)
  createdAt DateTime @default(now()) @map("created_at")

  projectItems ProjectItem[]
  orderItems OrderItem[]
}

model GlassType {
  id        String   @id @default(uuid())
  code      String?
  name      String
  widthMm   Float?   @map("width_mm")
  heightMm  Float?   @map("height_mm")
  status    ProductStatus @default(active)
  createdAt DateTime @default(now()) @map("created_at")

  formulas Formula[]
  projectItems ProjectItem[]
}

model GlassThickness {
  id        String   @id @default(uuid())
  code      String?
  thicknessMm Int    @map("thickness_mm")
  status    ProductStatus @default(active)
  createdAt DateTime @default(now()) @map("created_at")

  formulas Formula[]
  projectItems ProjectItem[]
}

model Warehouse {
  id        String         @id @default(uuid())
  code      String
  name      String
  status    WarehouseStatus @default(active)
  createdAt DateTime       @default(now()) @map("created_at")

  inventory      Inventory[]
  products       Product[]
  stockMovements StockMovement[]
}

model Inventory {
  id                 String   @id @default(uuid())
  warehouseId        String   @map("warehouse_id")
  productId          String   @map("product_id")
  qtyOnHand          Int      @default(0) @map("qty_on_hand")
  lowStockThreshold  Int      @default(5) @map("low_stock_threshold")
  updatedAt          DateTime @updatedAt @map("updated_at")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
}

model StockMovement {
  id          String              @id @default(uuid())
  warehouseId String              @map("warehouse_id")
  productId   String              @map("product_id")
  type        StockMovementType
  quantity    Int
  reference   String?
  note        String?
  createdBy   String?             @map("created_by")
  createdAt   DateTime            @default(now()) @map("created_at")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
  user      User?     @relation(fields: [createdBy], references: [id])

  @@map("stock_movements")
}

model Product {
  id            String        @id @default(uuid())
  sku           String        @unique
  name          String
  itemFormat    ItemFormat    @map("item_format")
  productTypeId String        @map("product_type_id")
  unitId        String        @map("unit_id")
  brandId       String?       @map("brand_id")
  warehouseId   String?       @map("warehouse_id")
  priceManual   Decimal?      @map("price_manual")
  priceSource   PriceSource   @default(MANUAL) @map("price_source")
  formulaId     String?       @map("formula_id")
  status        ProductStatus @default(active)
  description   String?
  imageUrl      String?       @map("image_url")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  productType ProductType @relation(fields: [productTypeId], references: [id])
  unit        Unit        @relation(fields: [unitId], references: [id])
  brand       Brand?      @relation(fields: [brandId], references: [id])
  warehouse   Warehouse?  @relation(fields: [warehouseId], references: [id])
  formula     Formula?    @relation("ProductFormula", fields: [formulaId], references: [id])
  mtoFormulas Formula[]   @relation("FormulaMtoProduct")
  orderItems  OrderItem[]
  inventory   Inventory[]
  stockMovements StockMovement[]
  projectItems ProjectItem[]
  formulaItems FormulaItem[]
}

model Formula {
  id                 String   @id @default(uuid())
  code               String
  name               String
  description        String?
  sequenceNumber     Int?     @map("sequence_number")
  productionQuantity Int?     @map("production_quantity")
  productTypeId      String?  @map("product_type_id")
  unitId             String?  @map("unit_id")
  standardWidth      Int      @map("standard_width")
  standardHeight     Int      @map("standard_height")
  standardLength     Int      @map("standard_length")
  glassTypeId        String?  @map("glass_type_id")
  glassThicknessId   String?  @map("glass_thickness_id")
  glassWidthOffset   Int?     @default(100) @map("glass_width_offset")
  glassHeightOffset  Int?     @default(100) @map("glass_height_offset")
  modelPath          String?  @map("model_path")
  productPrice       Decimal? @map("product_price")
  totalPrice         Decimal? @map("total_price")
  productId          String?  @map("product_id")
  createdAt          DateTime @default(now()) @map("created_at")

  items          FormulaItem[]
  products       Product[]       @relation("ProductFormula")
  product        Product?        @relation("FormulaMtoProduct", fields: [productId], references: [id])
  projectItems   ProjectItem[]
  glassType      GlassType?      @relation(fields: [glassTypeId], references: [id])
  glassThickness GlassThickness? @relation(fields: [glassThicknessId], references: [id])
  productType    ProductType?    @relation(fields: [productTypeId], references: [id])
  unit           Unit?           @relation(fields: [unitId], references: [id])
}

model FormulaItem {
  id            String  @id @default(uuid())
  formulaId     String  @map("formula_id")
  productId     String  @map("product_id")
  position      String?
  lengthMm      Int     @map("length_mm")
  qty           Int
  totalLengthMm Int?    @map("total_length_mm")
  angle         String?

  formula Formula @relation(fields: [formulaId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Project {
  id           String      @id @default(uuid())
  code         String?
  name         String
  customerName String      @map("customer_name")
  phone        String
  taxId        String?     @map("tax_id")
  houseNo      String?     @map("house_no")
  moo          String?
  building     String?
  soi          String?
  road         String?
  province     String?
  district     String?
  subdistrict  String?
  postalCode   String?     @map("postal_code")
  status       ProjectStatus @default(draft)
  createdById  String      @map("created_by_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  createdBy User         @relation(fields: [createdById], references: [id])
  items     ProjectItem[]
  quotations Quotation[]
  orders    Order[]
}

model ProjectItem {
  id                   String   @id @default(uuid())
  projectId            String   @map("project_id")
  productId            String?  @map("product_id")
  formulaId            String?  @map("formula_id")
  colorId              String?  @map("color_id")
  brandId              String?  @map("brand_id")
  width                Int?
  height               Int?
  length               Int?
  panelCount           Int?     @map("panel_count")
  quantity             Int?
  unit                 String?
  glassTypeId          String?  @map("glass_type_id")
  glassThicknessId     String?  @map("glass_thickness_id")
  glassWidth           Int?     @map("glass_width")
  glassHeight          Int?     @map("glass_height")
  glassThicknessMm     Float?   @map("glass_thickness_mm")
  glassQuantity        Int?     @map("glass_quantity")
  price                Decimal?
  status               ProjectItemStatus @default(DRAFT)

  project              Project          @relation(fields: [projectId], references: [id])
  product              Product?         @relation(fields: [productId], references: [id])
  formula              Formula?         @relation(fields: [formulaId], references: [id])
  color                Color?           @relation(fields: [colorId], references: [id])
  brand                Brand?           @relation(fields: [brandId], references: [id])
  glassType            GlassType?       @relation(fields: [glassTypeId], references: [id])
  glassThicknessRel    GlassThickness?  @relation(fields: [glassThicknessId], references: [id])
}

model Quotation {
  id                    String      @id @default(uuid())
  projectId             String      @map("project_id")
  version               Int         @default(1)
  status                QuoteStatus @default(draft)
  notes                 String?
  internalNotes         String?     @map("internal_notes")
  discount              Decimal     @default(0)
  vatEnabled            Boolean     @default(false) @map("vat_enabled")
  withholdingTaxPercent Decimal     @default(0)     @map("withholding_tax_percent")
  employeeName          String?     @map("employee_name")
  referenceNo           String?     @map("reference_no")
  description           String?
  quotationDate         DateTime?   @map("quotation_date")
  creditDays            Int         @default(0)     @map("credit_days")
  dueDate               DateTime?   @map("due_date")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt      @map("updated_at")

  project Project          @relation(fields: [projectId], references: [id])
  items   QuotationItem[]
}

model QuotationItem {
  id          String   @id @default(uuid())
  quotationId String   @map("quotation_id")
  description String
  qty         Int
  unit        String?
  unitPrice   Decimal  @map("unit_price")
  total       Decimal

  quotation Quotation @relation(fields: [quotationId], references: [id])
}

model Order {
  id        String      @id @default(uuid())
  code      String
  projectId String?     @map("project_id")
  status    OrderStatus @default(awaiting_payment)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  project   Project?  @relation(fields: [projectId], references: [id])
  items     OrderItem[]
  payments  Payment[]
  etax      EtaxRequest?
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String  @map("order_id")
  productId  String  @map("product_id")
  colorId    String? @map("color_id")
  brandId    String? @map("brand_id")
  width      Int?
  height     Int?
  thickness  Float?
  qty        Int
  unitPrice  Decimal @map("unit_price")
  totalPrice Decimal @map("total_price")

  order   Order    @relation(fields: [orderId], references: [id])
  product Product  @relation(fields: [productId], references: [id])
  color   Color?   @relation(fields: [colorId], references: [id])
  brand   Brand?   @relation(fields: [brandId], references: [id])
}

model Payment {
  id        String        @id @default(uuid())
  orderId   String        @map("order_id")
  slipUrl   String        @map("slip_url")
  status    PaymentStatus @default(pending)
  approvedBy String?      @map("approved_by")
  approvedAt DateTime?    @map("approved_at")
  createdAt DateTime      @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])
  admin User? @relation(fields: [approvedBy], references: [id])
}

model EtaxRequest {
  id          String   @id @default(uuid())
  orderId     String   @unique @map("order_id")
  legalName   String   @map("legal_name")
  taxId       String   @map("tax_id")
  houseNo     String?  @map("house_no")
  moo         String?
  road        String?
  province    String?
  district    String?
  subdistrict String?
  postalCode  String?  @map("postal_code")
  createdAt   DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])
}

model Notification {
  id        String             @id @default(uuid())
  userId    String             @map("user_id")
  message   String
  tone      NotificationTone
  status    NotificationStatus @default(unread)
  createdAt DateTime           @default(now()) @map("created_at")
  readAt    DateTime?          @map("read_at")

  user User @relation(fields: [userId], references: [id])
}
